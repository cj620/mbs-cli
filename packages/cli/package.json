{
  "name": "@mb-it-org/cli",
  "version": "0.1.35",
  "type": "module",
  "bin": {
    "mbs": "bin/run.js"
  },
  "oclif": {
    "bin": "mbs",
    "dirname": "mbs",
    "commands": {
      "strategy": "pattern",
      "glob": "dist/commands/**/*.js",
      "target": "./dist/commands"
    },
    "topicSeparator": " ",
    "plugins": [
      "@mb-it-org/org"
    ],
    "additionalVersionFlags": [],
    "node": {
      "version": "20.19.1"
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "pnpm exec vitest run"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@mb-it-org/org": "workspace:*",
    "@mb-it-org/shared": "workspace:*",
    "@oclif/core": "^4",
    "playwright-core": "^1.44.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "oclif": "^4",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  }
}
